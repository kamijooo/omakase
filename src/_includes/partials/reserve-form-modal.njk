        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">お名前 / Name *</label><input id="r_name" type="text" placeholder="Yamada Taro" autocomplete="name" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>
        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">メールアドレス / Email *</label><input id="r_email" type="email" placeholder="example@email.com" autocomplete="email" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>
        <div style="margin-bottom:16px;"><label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:6px;">電話番号 / Phone *</label><input id="r_phone" type="tel" placeholder="+81 90-0000-0000" autocomplete="tel" style="width:100%;background:#1a1a1a;border:1px solid rgba(201,169,110,0.25);border-radius:8px;padding:10px 14px;color:#f0ede4;font-size:16px;box-sizing:border-box;-webkit-appearance:none;"/></div>

        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:10px;letter-spacing:0.15em;color:rgba(201,169,110,0.7);text-transform:uppercase;margin-bottom:8px;">コース / Course *</label>

          {# Course cards — same SUMI / BOKUGA / BOKUSHOU across all stores #}
          <label class="form-course-card" id="course-card-sumi" onclick="selectCourse('sumi')">
            <input type="radio" name="r_course_radio" value="SUMI - ¥39,800 (¥43,780 inc.tax) / 13 courses · 60-75 min"/>
            <span class="check-mark"></span>
            <div class="form-course-card-tier">Entry Course</div>
            <div class="form-course-card-name">SUMI — 墨 —</div>
            <div class="form-course-card-price">
              <span class="form-course-card-price-main">¥39,800</span>
              <span class="form-course-card-price-tax">(¥43,780 inc.tax)</span>
            </div>
            <div class="form-course-card-meta">13 courses · 60–75 min</div>
            <div class="form-course-card-details">
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">序</span><span>Tofu · Yukhoe &amp; Hyogo Nori</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">八寸</span><span>Seasonal Appetizer (6 kinds)</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">温物</span><span>Wagyu Shabu-shabu &amp; Dashi</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">鮨</span><span>Temaki · Pressed Sushi · Wagyu Nigiri</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">椀</span><span>Aka-dashi Miso</span></div>
            </div>
          </label>

          <label class="form-course-card popular" id="course-card-bokuga" onclick="selectCourse('bokuga')">
            <input type="radio" name="r_course_radio" value="BOKUGA - ¥49,800 (¥54,780 inc.tax) / 15 courses · 75-90 min"/>
            <span class="check-mark"></span>
            <div class="form-course-card-tier">Premium Course</div>
            <div class="form-course-card-name">BOKUGA — 墨雅 —</div>
            <div class="form-course-card-price">
              <span class="form-course-card-price-main">¥49,800</span>
              <span class="form-course-card-price-tax">(¥54,780 inc.tax)</span>
            </div>
            <div class="form-course-card-meta">15 courses · 75–90 min</div>
            <div class="form-course-card-details">
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">序</span><span>Tofu · Yukhoe &amp; Hyogo Nori</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">八寸</span><span>Seasonal Appetizer Collection</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">温物</span><span>Wagyu Shabu-shabu &amp; Dashi</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">逸品</span><span>Wagyu &amp; Shiso Spring Roll · "Cheese Snow"</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">鮨</span><span>Temaki · Pressed Sushi · Wagyu Nigiri</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">椀</span><span>Aka-dashi Miso</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">茶と甘味</span><span>Matcha — Tsujiri · Wagashi 6 kinds</span></div>
            </div>
          </label>

          <label class="form-course-card" id="course-card-bokushou" onclick="selectCourse('bokushou')">
            <input type="radio" name="r_course_radio" value="BOKUSHOU - ¥89,800 (¥98,780 inc.tax) / 20 courses · 120 min"/>
            <span class="check-mark"></span>
            <div class="form-course-card-tier">Ultimate Course</div>
            <div class="form-course-card-name">BOKUSHOU — 墨匠 —</div>
            <div class="form-course-card-price">
              <span class="form-course-card-price-main">¥89,800</span>
              <span class="form-course-card-price-tax">(¥98,780 inc.tax)</span>
            </div>
            <div class="form-course-card-meta">20 courses · 120 min</div>
            <div class="form-course-card-details">
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">序</span><span>Tofu · Yukhoe &amp; Hyogo Nori</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">八寸</span><span>Seasonal Appetizer Collection</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">温物</span><span>Wagyu Shabu-shabu &amp; Dashi</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">鮨</span><span>Temaki: Uni / Salmon &amp; Ikura · Pressed Sushi · Wagyu Nigiri</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">逸品</span><span>Jet-Black Vichyssoise · Wagyu Spring Roll</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">和牛</span><span>Wagyu Steak "Tanto" · Mini Burger</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">お口直し</span><span>Yuzu Sorbet with Gold Leaf</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">椀</span><span>Aka-dashi Miso</span></div>
              <div class="form-course-card-details-row"><span class="form-course-card-details-label">茶と甘味</span><span>Matcha — Tsujiri · Wagashi 6 kinds</span></div>
            </div>
